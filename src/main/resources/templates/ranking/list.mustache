<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>랭킹 | 갓생 업</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .ranking-row {
            cursor: pointer;
        }
    </style>
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/main">갓생 업</a>
        <div class="ms-auto">
            <a href="/main" class="btn btn-outline-dark btn-sm">메인으로</a>
        </div>
    </div>
</nav>

<main class="container py-4 py-lg-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-4">
                <div>
                    <h1 class="h3 mb-0">전체 랭킹</h1>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">순위</th>
                                <th class="py-3">닉네임</th>
                                <th class="py-3 text-end">레벨</th>
                                <th class="px-4 py-3 text-end">EXP</th>
                            </tr>
                            </thead>
                            <tbody>
                            {{#rankings}}
                                <tr class="ranking-row {{#isMe}}table-warning{{/isMe}}">
                                    <td class="px-4 py-3 fw-semibold">
                                        <a href="/user/{{nickname}}" class="link-dark text-decoration-none d-block">{{rank}}</a>
                                    </td>
                                    <td class="py-3">
                                        <a href="/user/{{nickname}}" class="link-dark text-decoration-none d-flex align-items-center gap-3">
                                            <img src="{{characterImage}}" alt="{{characterName}}" class="rounded" style="width: 24px; height: 24px; object-fit: contain;">
                                            <div>
                                                <div>
                                                    {{nickname}}
                                                    {{#isMe}}
                                                        <span class="badge text-bg-dark ms-2">Me!</span>
                                                    {{/isMe}}
                                                </div>
                                                <div class="small text-secondary">{{characterName}}</div>
                                            </div>
                                        </a>
                                    </td>
                                    <td class="py-3 text-end">
                                        <a href="/user/{{nickname}}" class="link-dark text-decoration-none d-block">Lv. {{level}}</a>
                                    </td>
                                    <td class="px-4 py-3 text-end">
                                        <a href="/user/{{nickname}}" class="link-dark text-decoration-none d-block">{{exp}}</a>
                                    </td>
                                </tr>
                            {{/rankings}}
                            {{^rankings}}
                                <tr>
                                    <td colspan="4" class="px-4 py-5 text-center text-secondary">
                                        아직 랭킹 데이터가 없습니다.
                                    </td>
                                </tr>
                            {{/rankings}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <nav class="mt-4" aria-label="랭킹 페이지 이동">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item {{^hasPrevious}}disabled{{/hasPrevious}}">
                        <a class="page-link" href="/ranking?page={{previousPage}}">이전</a>
                    </li>

                    {{#pageNumbers}}
                        <li class="page-item {{#active}}active{{/active}}">
                            <a class="page-link" href="/ranking?page={{page}}">{{displayPage}}</a>
                        </li>
                    {{/pageNumbers}}

                    <li class="page-item {{^hasNext}}disabled{{/hasNext}}">
                        <a class="page-link" href="/ranking?page={{nextPage}}">다음</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</main>
</body>
</html>
