<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{nickname}} | 공개 프로필</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container">
        <a class="navbar-brand fw-bold" href="/">갓생 업</a>
        <div class="ms-auto d-flex gap-2">
            <a href="/ranking" class="btn btn-outline-dark btn-sm">랭킹으로</a>
            <a href="/main" class="btn btn-dark btn-sm">메인으로</a>
        </div>
    </div>
</nav>

<main class="container py-4 py-lg-5">
    <section class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 p-lg-5">
            <div class="row g-4 align-items-center">
                <div class="col-12 col-md-8">
                    <h1 class="h2 mb-2">{{nickname}}</h1>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge text-bg-dark">Lv. {{level}}</span>
                        <span class="badge text-bg-secondary">{{characterName}}</span>
                        <span class="badge text-bg-light">EXP {{exp}}</span>
                    </div>
                    <p class="text-secondary mb-0">수행 완료한 미션만 공개되며, 날짜별로 상·중·하 기록을 확인할 수 있습니다.</p>
                </div>
                <div class="col-12 col-md-4 text-md-end">
                    <img src="{{characterImage}}" alt="{{characterName}}" class="img-fluid" style="max-width: 160px; max-height: 160px; object-fit: contain;">
                </div>
            </div>
        </div>
    </section>

    <section class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <p class="text-secondary small mb-1">MISSION HISTORY</p>
                    <h2 class="h4 mb-0">수행 기록</h2>
                </div>
            </div>

            <div id="mission-history">
                {{#missionGroups}}
                    <section class="mb-4 history-group">
                        <div class="border-bottom pb-2 mb-3">
                            <h3 class="h6 mb-0">{{date}}</h3>
                        </div>

                        <div class="row g-3">
                            {{#missions}}
                                <div class="col-12">
                                    <div class="border rounded-4 p-3 bg-white">
                                        <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center">
                                            <img src="{{imageUrl}}" alt="{{difficultyLabel}} 미션" class="rounded border" style="width: 120px; height: 120px; object-fit: cover;">
                                            <div class="flex-grow-1">
                                                <div class="d-flex flex-wrap gap-2 mb-2">
                                                    <span class="badge {{difficultyClass}}">{{difficultyLabel}}</span>
                                                    {{#completed}}
                                                        <span class="badge text-bg-success">수행 완료</span>
                                                    {{/completed}}
                                                    {{^completed}}
                                                        <span class="badge text-bg-secondary">수행하지 않음</span>
                                                    {{/completed}}
                                                </div>
                                                <div class="fw-semibold">{{content}}</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {{/missions}}
                        </div>
                    </section>
                {{/missionGroups}}

                {{^missionGroups}}
                    <div class="border rounded p-4 bg-white text-center text-secondary">
                        아직 공개된 수행 기록이 없습니다.
                    </div>
                {{/missionGroups}}
            </div>

            <div id="history-loading" class="text-center text-secondary small py-3 d-none">
                기록을 불러오는 중입니다...
            </div>
            <div id="history-end" class="text-center text-secondary small py-3 d-none">
                더 이상 불러올 기록이 없습니다.
            </div>
            <div id="history-sentinel"
                 data-nickname="{{nickname}}"
                 data-next-cursor="{{nextCursor}}"
                 data-has-next="{{hasNext}}">
            </div>
        </div>
    </section>
</main>

<script>
    (() => {
        const historyRoot = document.getElementById('mission-history');
        const sentinel = document.getElementById('history-sentinel');
        const loading = document.getElementById('history-loading');
        const end = document.getElementById('history-end');

        let nextCursor = sentinel.dataset.nextCursor || '';
        let hasNext = sentinel.dataset.hasNext === 'true';
        let isLoading = false;
        const nickname = sentinel.dataset.nickname;

        if (!hasNext) {
            end.classList.remove('d-none');
        }

        const observer = new IntersectionObserver(async (entries) => {
            const entry = entries[0];
            if (!entry.isIntersecting || !hasNext || isLoading) {
                return;
            }

            isLoading = true;
            loading.classList.remove('d-none');

            try {
                const response = await fetch(`/api/user/${encodeURIComponent(nickname)}/missions?cursor=${encodeURIComponent(nextCursor)}`);
                const data = await response.json();
                appendGroups(data.missionGroups);
                hasNext = data.hasNext;
                nextCursor = data.nextCursor || '';
                sentinel.dataset.nextCursor = nextCursor;
                sentinel.dataset.hasNext = String(hasNext);

                if (!hasNext) {
                    end.classList.remove('d-none');
                    observer.disconnect();
                }
            } finally {
                isLoading = false;
                loading.classList.add('d-none');
            }
        }, { rootMargin: '200px' });

        observer.observe(sentinel);

        function appendGroups(groups) {
            groups.forEach(group => {
                const section = document.createElement('section');
                section.className = 'mb-4 history-group';
                section.innerHTML = `
                    <div class="border-bottom pb-2 mb-3">
                        <h3 class="h6 mb-0">${escapeHtml(group.date)}</h3>
                    </div>
                    <div class="row g-3">
                        ${group.missions.map(renderMission).join('')}
                    </div>
                `;
                historyRoot.appendChild(section);
            });
        }

        function renderMission(mission) {
            const statusBadge = mission.completed
                ? '<span class="badge text-bg-success">수행 완료</span>'
                : '<span class="badge text-bg-secondary">수행하지 않음</span>';

            return `
                <div class="col-12">
                    <div class="border rounded-4 p-3 bg-white">
                        <div class="d-flex flex-column flex-md-row gap-3 align-items-md-center">
                            <img src="${escapeHtml(mission.imageUrl)}" alt="${escapeHtml(mission.difficultyLabel)} 미션" class="rounded border" style="width: 120px; height: 120px; object-fit: cover;">
                            <div class="flex-grow-1">
                                <div class="d-flex flex-wrap gap-2 mb-2">
                                    <span class="badge ${escapeHtml(mission.difficultyClass)}">${escapeHtml(mission.difficultyLabel)}</span>
                                    ${statusBadge}
                                </div>
                                <div class="fw-semibold">${escapeHtml(mission.content)}</div>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }
    })();
</script>
</body>
</html>
